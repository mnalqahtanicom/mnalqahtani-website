# Public site URL (used for canonical URLs, sitemap, OG, JSON-LD)
NEXT_PUBLIC_SITE_URL=https://mnalqahtani.com

# --- Sanity CMS (Insights/Articles) ---
# Without these the site uses in-repo seed articles. Set them to activate
# the live CMS + the /studio dashboard. See docs/PUBLISHING.md.
# NEXT_PUBLIC_SANITY_PROJECT_ID=
# NEXT_PUBLIC_SANITY_DATASET=production
# NEXT_PUBLIC_SANITY_API_VERSION=2024-10-01

# --- Contact form email provider (when wired up) ---
# RESEND_API_KEY=
